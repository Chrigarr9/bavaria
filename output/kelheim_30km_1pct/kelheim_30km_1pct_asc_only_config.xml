<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE config SYSTEM "http://www.matsim.org/files/dtd/config_v2.dtd">

<!-- Bavaria 30km eqasim scenario config — 1% sample for calibration.
     Network/schedule/vehicles: reused from kelheim_30km_100pct output (same files).
     Population: warm-started from previous eqasim run (pre-routed, multi-modal plans).
     This config is designed to be used with org.eqasim.bavaria.RunSimulation via boptx
     MATSimEvaluator, which overrides: outputDirectory, lastIteration, numberOfThreads,
     and all mode-choice-parameter values.
-->
<config>

	<!-- =================================================================== -->
	<!-- eqasim discrete mode choice settings (Bavaria flavour)              -->
	<!-- =================================================================== -->
	<module name="DiscreteModeChoice" >
		<param name="accumulateEstimationDelays" value="true" />
		<param name="cachedModes" value="bicycle, pt, car, truck, car_passenger, walk" />
		<param name="enforceSinglePlan" value="true" />
		<param name="fallbackBehaviour" value="EXCEPTION" />
		<param name="homeFinder" value="EqasimHomeFinder" />
		<param name="modeAvailability" value="BavariaModeAvailability" />
		<param name="modelType" value="Tour" />
		<!-- Routes are cached in synthesis plans — no need to reroute every iteration -->
		<param name="performReroute" value="false" />
		<param name="selector" value="Maximum" />
		<param name="tourConstraints" value="FromTripBased, EqasimVehicleTourConstraint" />
		<param name="tourEstimator" value="Cumulative" />
		<param name="tourFilters" value="TourLengthFilter, OutsideFilter" />
		<param name="tourFinder" value="ActivityBased" />
		<param name="tripConstraints" value="OutsideConstraint, TransitWalk" />
		<param name="tripEstimator" value="EqasimUtilityEstimator" />
		<param name="tripFilters" value="" />
		<param name="writeUtilitiesInterval" value="1" />
		<parameterset type="homeFinder:ActivityBased" >
			<param name="activityTypes" value="home" />
		</parameterset>
		<parameterset type="modeAvailability:Car" >
			<param name="availableModes" value="pt, car, walk, bike" />
		</parameterset>
		<parameterset type="modeAvailability:Default" >
			<param name="availableModes" value="pt, car, walk, bike" />
		</parameterset>
		<parameterset type="selector:MultinomialLogit" >
			<param name="considerMinimumUtility" value="false" />
			<param name="maximumUtility" value="700.0" />
			<param name="minimumUtility" value="-700.0" />
		</parameterset>
		<parameterset type="tourConstraint:SubtourMode" >
			<param name="constrainedModes" value="" />
		</parameterset>
		<parameterset type="tourConstraint:VehicleContinuity" >
			<param name="restrictedModes" value="bicycle, car" />
		</parameterset>
		<parameterset type="tourFilter:TourLength" >
			<param name="maximumLength" value="10" />
		</parameterset>
		<parameterset type="tourFinder:ActivityBased" >
			<param name="activityTypes" value="outside, home" />
		</parameterset>
		<parameterset type="tripConstraint:LinkAttribute" >
			<param name="attributeName" value="null" />
			<param name="attributeValue" value="null" />
			<param name="constrainedModes" value="" />
			<param name="requirement" value="BOTH" />
		</parameterset>
		<parameterset type="tripConstraint:ShapeFile" >
			<param name="constrainedModes" value="" />
			<param name="path" value="null" />
			<param name="requirement" value="BOTH" />
		</parameterset>
		<parameterset type="tripConstraint:VehicleContinuity" >
			<param name="isAdvanced" value="true" />
			<param name="restrictedModes" value="car, bike" />
		</parameterset>
		<parameterset type="tripEstimator:MATSimTripScoring" >
			<param name="ptLegModes" value="pt" />
		</parameterset>
	</module>

	<!-- =================================================================== -->
	<!-- Controller / output                                                  -->
	<!-- =================================================================== -->
	<module name="controller" >
		<param name="cleanItersAtEnd" value="keep" />
		<param name="compressionType" value="gzip" />
		<param name="createGraphsInterval" value="0" />
		<param name="firstIteration" value="0" />
		<!-- boptx overrides lastIteration via config:controler.lastIteration -->
		<param name="lastIteration" value="1" />
		<param name="mobsim" value="qsim" />
		<!-- boptx overrides outputDirectory via config:controler.outputDirectory -->
		<param name="outputDirectory" value="output" />
		<param name="overwriteFiles" value="deleteDirectoryIfExists" />
		<param name="routingAlgorithmType" value="SpeedyALT" />
		<param name="runId" value="null" />
		<param name="writeEventsInterval" value="0" />
		<param name="writePlansInterval" value="0" />
		<param name="writeSnapshotsInterval" value="0" />
		<!-- Must be ≤ lastIteration to get trips written; -1 disables per-iter, dumpDataAtEnd covers final -->
		<param name="writeTripsInterval" value="1" />
		<param name="dumpDataAtEnd" value="true" />
	</module>

	<!-- =================================================================== -->
	<!-- eqasim core settings                                                 -->
	<!-- =================================================================== -->
	<module name="eqasim" >
		<param name="analysisDistanceUnit" value="meter" />
		<param name="analysisInterval" value="1000" />
		<param name="costParametersPath" value="null" />
		<param name="crossingPenalty" value="4.2" />
		<param name="distanceUnit" value="meter" />
		<param name="modeParametersPath" value="null" />
		<!-- 1% sample -->
		<param name="sampleSize" value="0.01" />
		<param name="travelTimeRecordingInterval" value="0" />
		<param name="usePseudoRandomErrors" value="true" />
		<param name="useScheduleBasedTransport" value="true" />
		<parameterset type="cost_model" >
			<param name="mode" value="car" />
			<param name="model" value="BavariaCarCostModel" />
		</parameterset>
		<parameterset type="cost_model" >
			<param name="mode" value="pt" />
			<param name="model" value="MunichPtCostModel" />
		</parameterset>
		<parameterset type="estimator" >
			<param name="estimator" value="BavariaCarUtilityEstimator" />
			<param name="mode" value="car" />
		</parameterset>
		<parameterset type="estimator" >
			<param name="estimator" value="BavariaPtUtilityEstimator" />
			<param name="mode" value="pt" />
		</parameterset>
		<parameterset type="estimator" >
			<param name="estimator" value="WalkUtilityEstimator" />
			<param name="mode" value="walk" />
		</parameterset>
		<parameterset type="estimator" >
			<param name="estimator" value="ZeroUtilityEstimator" />
			<param name="mode" value="outside" />
		</parameterset>
		<parameterset type="estimator" >
			<param name="estimator" value="BavariaCarPassengerUtilityEstimator" />
			<param name="mode" value="car_passenger" />
		</parameterset>
		<parameterset type="estimator" >
			<param name="estimator" value="ZeroUtilityEstimator" />
			<param name="mode" value="truck" />
		</parameterset>
		<parameterset type="estimator" >
			<param name="estimator" value="BavariaBicycleUtilityEstimator" />
			<param name="mode" value="bicycle" />
		</parameterset>
	</module>

	<!-- eqasim RAPTOR parameters (PT utility decomposition for routing) -->
	<module name="eqasim:raptor" >
		<param name="perTransfer_u" value="-0.5441109013512305" />
		<param name="travelTimeBus_u_h" value="-2.835025304050246" />
		<param name="travelTimeOther_u_h" value="-2.835025304050246" />
		<param name="travelTimeRail_u_h" value="-1.4278139352278472" />
		<param name="travelTimeSubway_u_h" value="-1.0" />
		<param name="travelTimeTram_u_h" value="-3.199594607188756" />
		<param name="waitTime_u_h" value="-0.497984826174775" />
		<param name="walkTime_u_h" value="-3.8494071051697385" />
	</module>

	<!-- eqasim termination check -->
	<module name="eqasim:termination" >
		<param name="historyFile" value="null" />
		<param name="horizon" value="10" />
		<param name="minimumIterations" value="0" />
		<param name="modes" value="car,car_passenger,pt,bicycle,walk" />
		<param name="smoothing" value="20" />
		<param name="threshold" value="0.001" />
	</module>

	<!-- =================================================================== -->
	<!-- Facilities — not used, activities use coordinates from plans         -->
	<!-- =================================================================== -->
	<module name="facilities" >
		<param name="facilitiesSource" value="none" />
		<param name="inputFacilitiesFile" value="null" />
	</module>

	<!-- =================================================================== -->
	<!-- Global                                                               -->
	<!-- =================================================================== -->
	<module name="global" >
		<!-- "Atlantis" is Bavaria eqasim internal CRS name (EPSG:32632) -->
		<param name="coordinateSystem" value="Atlantis" />
		<param name="defaultDelimiter" value=";" />
		<param name="insistingOnDeprecatedConfigVersion" value="true" />
		<!-- boptx overrides via config:global.numberOfThreads -->
		<param name="numberOfThreads" value="8" />
		<param name="randomSeed" value="1234" />
	</module>

	<!-- =================================================================== -->
	<!-- Households — not needed (income is a person attribute from synthesis) -->
	<!-- =================================================================== -->
	<module name="households" >
		<param name="inputFile" value="null" />
	</module>

	<!-- =================================================================== -->
	<!-- Network                                                              -->
	<!-- =================================================================== -->
	<module name="network" >
		<param name="inputNetworkFile" value="C:\Users\VWAUCCY\dev\msf\projects\Dissertation\matsim_scenarios\bavaria\output\kelheim_30km_100pct\kelheim_30km_100pct_network.xml.gz" />
	</module>

	<!-- =================================================================== -->
	<!-- Population / plans                                                   -->
	<!-- Warm-started from eval 1e268cb376 (prev best eqasim run, 1 iter).  -->
	<!-- Agents have pre-routed multi-modal plans → iteration-0 mode shares  -->
	<!-- already reflect sensible travel choices.                             -->
	<!-- =================================================================== -->
	<module name="plans" >
		<param name="activityDurationInterpretation" value="tryEndTimeThenDuration" />
		<param name="handlingOfPlansWithoutRoutingMode" value="reject" />
		<param name="inputPlansFile" value="C:\Users\VWAUCCY\dev\msf\projects\Dissertation\matsim_scenarios\bavaria\calibration\boptx\work\1e268cb376fd5acbe2285e2c01651f21\output\output_plans.xml.gz" />
		<param name="networkRouteType" value="LinkNetworkRoute" />
		<param name="removingUnnecessaryPlanAttributes" value="false" />
		<param name="tripDurationHandling" value="shiftActivityEndTimes" />
	</module>

	<!-- =================================================================== -->
	<!-- QSim (1% capacities)                                                 -->
	<!-- =================================================================== -->
	<module name="qsim" >
		<param name="endTime" value="30:00:00" />
		<param name="flowCapacityFactor" value="0.01" />
		<param name="insertingWaitingVehiclesBeforeDrivingVehicles" value="true" />
		<param name="linkDynamics" value="FIFO" />
		<param name="mainMode" value="car" />
		<!-- boptx overrides via config:qsim.numberOfThreads -->
		<param name="numberOfThreads" value="8" />
		<param name="removeStuckVehicles" value="false" />
		<param name="storageCapacityFactor" value="0.01" />
		<param name="stuckTime" value="10.0" />
		<param name="timeStepSize" value="00:00:01" />
		<param name="trafficDynamics" value="queue" />
		<param name="usePersonIdForMissingVehicleId" value="true" />
		<param name="usingFastCapacityUpdate" value="true" />
		<param name="vehicleBehavior" value="teleport" />
		<param name="vehiclesSource" value="fromVehiclesData" />
	</module>

	<!-- =================================================================== -->
	<!-- Replanning: 100% DiscreteModeChoice (ASC-only calibration variant)  -->
	<!-- With lastIteration=1 every agent is re-mode-chosen exactly once     -->
	<!-- using the current parameter set, so each boptx eval sees a true     -->
	<!-- parameter response instead of 95% warm-start noise.                 -->
	<!-- KeepLastSelected must be listed (not weight-checked) because        -->
	<!-- DiscreteModeChoiceConfigurator.checkModeChoiceInTheLoop requires    -->
	<!-- it as an "active" strategy — weight 0.0 is accepted and means it   -->
	<!-- is never drawn. maxAgentPlanMemorySize=1 → pure DMC.                -->
	<!-- =================================================================== -->
	<module name="replanning" >
		<param name="fractionOfIterationsToDisableInnovation" value="Infinity" />
		<param name="maxAgentPlanMemorySize" value="1" />
		<param name="planSelectorForRemoval" value="NonSelectedPlanSelector" />
		<parameterset type="strategysettings" >
			<param name="strategyName" value="DiscreteModeChoice" />
			<param name="subpopulation" value="null" />
			<param name="weight" value="1.0" />
		</parameterset>
		<parameterset type="strategysettings" >
			<param name="strategyName" value="KeepLastSelected" />
			<param name="subpopulation" value="null" />
			<param name="weight" value="0.0" />
		</parameterset>
	</module>

	<!-- =================================================================== -->
	<!-- Routing                                                              -->
	<!-- =================================================================== -->
	<module name="routing" >
		<param name="accessEgressType" value="accessEgressModeToLink" />
		<param name="networkModes" value="car,truck,car_passenger" />
		<param name="routingRandomness" value="0.0" />
		<parameterset type="teleportedModeParameters" >
			<param name="beelineDistanceFactor" value="1.0" />
			<param name="mode" value="outside" />
			<param name="teleportedModeSpeed" value="1000.0" />
		</parameterset>
		<parameterset type="teleportedModeParameters" >
			<param name="beelineDistanceFactor" value="1.4" />
			<param name="mode" value="bike" />
			<param name="teleportedModeSpeed" value="3.1" />
		</parameterset>
		<parameterset type="teleportedModeParameters" >
			<param name="beelineDistanceFactor" value="1.3" />
			<param name="mode" value="walk" />
			<param name="teleportedModeSpeed" value="1.25" />
		</parameterset>
		<parameterset type="teleportedModeParameters" >
			<param name="beelineDistanceFactor" value="1.3" />
			<param name="mode" value="bicycle" />
			<param name="teleportedModeSpeed" value="4.166666666666667" />
		</parameterset>
	</module>

	<!-- =================================================================== -->
	<!-- Scoring (eqasim uses trip-based estimators, activity scoring = 0)   -->
	<!-- All activities have scoringThisActivityAtAll=false.                  -->
	<!-- =================================================================== -->
	<module name="scoring" >
		<param name="brainExpBeta" value="1.0" />
		<param name="learningRate" value="1.0" />
		<param name="usingOldScoringBelowZeroUtilityDuration" value="false" />
		<param name="writeExperiencedPlans" value="false" />
		<parameterset type="scoringParameters" >
			<param name="earlyDeparture" value="-0.0" />
			<param name="lateArrival" value="-18.0" />
			<param name="marginalUtilityOfMoney" value="0.0" />
			<param name="performing" value="6.0" />
			<param name="subpopulation" value="null" />
			<param name="utilityOfLineSwitch" value="-1.0" />
			<param name="waiting" value="-0.0" />
			<param name="waitingPt" value="-1.0" />
			<!-- interaction activities -->
			<parameterset type="activityParams" >
				<param name="activityType" value="car interaction" />
				<param name="scoringThisActivityAtAll" value="false" />
				<param name="typicalDuration" value="undefined" />
			</parameterset>
